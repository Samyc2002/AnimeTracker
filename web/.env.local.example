NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your-database-id
NEXT_PUBLIC_APPWRITE_WATCHLIST_COLLECTION_ID=your-watchlist-collection-id
NEXT_PUBLIC_APPWRITE_WATCHED_EPISODES_COLLECTION_ID=your-watched-episodes-collection-id
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=your-profiles-collection-id
NEXT_PUBLIC_APPWRITE_PLAYLISTS_COLLECTION_ID=your-playlists-collection-id

# Server-side only (for /api/stats endpoint)
# Create an API key in Appwrite Console > Project Settings > API Keys
# Required scopes: users.read, documents.read
APPWRITE_API_KEY=your-appwrite-api-key

# AniList OAuth (register at https://anilist.co/settings/developer)
# Set redirect URL to: http://localhost:3000/api/auth/anilist/callback
NEXT_PUBLIC_ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret
