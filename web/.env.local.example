NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AniList OAuth (register at https://anilist.co/settings/developer)
# Set redirect URL to: http://localhost:3000/api/auth/anilist/callback
NEXT_PUBLIC_ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret

# Cron secret for scheduled functions
CRON_SECRET=your-cron-secret
